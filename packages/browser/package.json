{
  "name": "@office-agents/browser",
  "version": "0.0.1",
  "type": "module",
  "description": "Browser-native CDP client for cloud browser automation. Works in any browser context — no Node.js required.",
  "license": "MIT",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "publishConfig": {
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/hewliyang/office-agents.git",
    "directory": "packages/browser"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "test": "vitest run --exclude tests/integration.test.ts --exclude tests/integration/",
    "test:integration": "vitest run tests/integration.test.ts tests/integration/",
    "test:install-browsers": "playwright install chromium"
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "@types/turndown": "^5.0.6",
    "linkedom": "^0.18.12",
    "turndown": "^7.2.2"
  },
  "devDependencies": {
    "devtools-protocol": "^0.0.1602427",
    "playwright": "1.57.0",
    "typescript": "^5.8.0"
  }
}
